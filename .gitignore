# Build artifacts
/target/
/dist/
.cas.log

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Local data
/.mem/
.cas/
.fallow/
/temp/
/index/

# Per-developer ephemeral docs (regenerated by /codemap; working-tree-dependent)
/.claude/CODEMAP.md

# Environment files (contain secrets)
.env
.env.local
.env.worktree

# Node modules
node_modules/

# Build toolchains
.zig-cache/
.context/

# Process sockets
.overmind.sock
# Worktree-specific files (generated per worktree)
# fallow incremental analysis cache (used by the fallow skill)

# Synced skill copies — rendered from cas-cli/src/builtins/{skills,codex/skills}
# by `cas update --sync`. The builtins are the source of truth; tracking the
# rendered output dirties the tree on every upstream skill change. Skills with
# NO builtin source (local-only) are kept tracked via the negations below.
/.claude/skills/*
!/.claude/skills/cas/
!/.claude/skills/cas-seo-expert/
!/.claude/skills/cas-servers/
/.codex/skills/
