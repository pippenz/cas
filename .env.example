# CAS Configuration
# Copy this to .env and fill in your keys for release builds.
# These are embedded at compile time - users don't need to set them.

# PostHog API key for anonymous usage analytics
CAS_POSTHOG_API_KEY=

# Sentry DSN for crash reporting
CAS_SENTRY_DSN=

# Supabase Configuration (for GitHub OAuth)
CAS_SUPABASE_URL=https://your-project.supabase.co
CAS_SUPABASE_ANON_KEY=your-supabase-anon-key
